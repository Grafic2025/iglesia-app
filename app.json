{
  "expo": {
    "name": "Iglesia del Salvador",
    "slug": "iglesia-app",
    "version": "1.1.11",
    "scheme": "iglesia-del-salvador",
    "icon": "./assets/images/Logo.png",
    "splash": {
      "image": "./assets/images/Logo.png",
      "resizeMode": "contain",
      "backgroundColor": "#000000"
    },
    "notification": {
      "icon": "./assets/images/notification_icon.png",
      "color": "#c5ff00",
      "iosDisplayInForeground": true
    },
    "updates": {
      "url": "https://u.expo.dev/1e371a5d-b4ee-46ee-9c28-40f9d567fd1f",
      "enabled": true
    },
    "android": {
      "package": "com.grafic2026.iglesiaapp",
      "versionCode": 11,
      "googleServicesFile": "./google-services.json",
      "adaptiveIcon": {
        "foregroundImage": "./assets/images/Logo.png",
        "backgroundColor": "#000000"
      },
      "permissions": [
        "android.permission.CAMERA",
        "android.permission.VIBRATE",
        "android.permission.INTERNET",
        "android.permission.POST_NOTIFICATIONS",
        "android.permission.WAKE_LOCK",
        "android.permission.USE_BIOMETRIC",
        "android.permission.USE_FINGERPRINT"
      ]
    },
    "plugins": [
      [
        "expo-camera",
        {
          "cameraPermission": "Permite que la app acceda a la cámara para registrar tu asistencia."
        }
      ],
      [
        "expo-local-authentication",
        {
          "faceIDPermission": "Permite que la app use Face ID para iniciar sesión de forma segura."
        }
      ],
      [
        "expo-image-picker",
        {
          "photosPermission": "Permite que la app acceda a tu galería para elegir una foto de perfil.",
          "cameraPermission": "Permite que la app use la cámara para tomar tu foto de perfil."
        }
      ],
      "expo-notifications",
      "expo-router",
      "expo-secure-store",
      "expo-font"
    ],
    "extra": {
      "eas": {
        "projectId": "1e371a5d-b4ee-46ee-9c28-40f9d567fd1f"
      }
    },
    "runtimeVersion": {
      "policy": "appVersion"
    },
    "ios": {
      "bundleIdentifier": "com.grafic2026.iglesiaapp",
      "buildNumber": "10",
      "supportsTablet": true,
      "privacyManifests": {
        "NSPrivacyAccessedAPITypes": [
          {
            "NSPrivacyAccessedAPIType": "NSPrivacyAccessedAPICategoryUserDefaults",
            "NSPrivacyAccessedAPITypeReasons": [
              "CA92.1"
            ]
          },
          {
            "NSPrivacyAccessedAPIType": "NSPrivacyAccessedAPICategoryFileTimestamp",
            "NSPrivacyAccessedAPITypeReasons": [
              "C617.1"
            ]
          },
          {
            "NSPrivacyAccessedAPIType": "NSPrivacyAccessedAPICategorySystemBootTime",
            "NSPrivacyAccessedAPITypeReasons": [
              "35F9.1"
            ]
          },
          {
            "NSPrivacyAccessedAPIType": "NSPrivacyAccessedAPICategoryDiskSpace",
            "NSPrivacyAccessedAPITypeReasons": [
              "85F4.1"
            ]
          }
        ]
      },
      "infoPlist": {
        "LSApplicationQueriesSchemes": [
          "fb",
          "mpago",
          "mercadopago",
          "whatsapp",
          "tiktok"
        ],
        "ITSAppUsesNonExemptEncryption": false
      }
    }
  }
}